<UserControl x:Class="WPFApp.Views.Admin.CreateStaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Create Staff Account"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Create a new staff account for the inventory management system."
                       FontSize="14"
                       Foreground="Gray"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="24"
                CornerRadius="10"
                BorderBrush="#DDD"
                BorderThickness="1"
                Background="White"
                MaxWidth="650"
                VerticalAlignment="Top" HorizontalAlignment="Center" Width="630" Height="516">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Full Name -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Full Name"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>
                    <TextBox x:Name="txtFullName"
                             Height="36"
                             FontSize="14"
                             Padding="10,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Email -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Email"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>
                    <TextBox x:Name="txtEmail"
                             Height="36"
                             FontSize="14"
                             Padding="10,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Password -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="Password"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>
                    <PasswordBox x:Name="txtPassword"
                                 Height="36"
                                 FontSize="14"
                                 Padding="10,0"/>
                </StackPanel>

                <!-- Phone -->
                <StackPanel Grid.Row="6">
                    <TextBlock Text="Phone"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>
                    <TextBox x:Name="txtPhone"
                             Height="36"
                             FontSize="14"
                             Padding="10,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <!-- Status -->
                <StackPanel Grid.Row="8">
                    <TextBlock Text="Status"
                               Margin="0,0,0,6"
                               FontWeight="SemiBold"/>
                    <ComboBox x:Name="cbStatus"
                              Height="36"
                              FontSize="14"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Active"/>
                        <ComboBoxItem Content="Inactive"/>
                    </ComboBox>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="10"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="btnReset"
                            Content="Reset"
                            Width="100"
                            Height="36"
                            Margin="0,0,10,0"
                            Click="btnReset_Click"/>
                    <Button x:Name="btnCreate"
                            Content="Create"
                            Width="120"
                            Height="36"
                            Click="btnCreate_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>