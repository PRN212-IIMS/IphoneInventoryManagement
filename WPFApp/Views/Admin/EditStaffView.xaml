<UserControl x:Class="WPFApp.Views.Admin.EditStaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1100">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Edit Staff Account"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Update staff account information."
                       FontSize="14"
                       Foreground="Gray"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="24"
                CornerRadius="10"
                BorderBrush="#DDD"
                BorderThickness="1"
                Background="White"
                MaxWidth="650"
                HorizontalAlignment="Left"
                VerticalAlignment="Center" Width="662" Margin="47,0,0,0" Height="479">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Full Name" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtFullName"
                             Height="36"
                             FontSize="14"
                             Padding="10,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="Email" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtEmail"
                             Height="36"
                             FontSize="14"
                             Padding="10,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="4">
                    <TextBlock Text="New Password (optional)" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="txtPassword"
                                 Height="36"
                                 FontSize="14"
                                 Padding="10,0"/>
                </StackPanel>

                <StackPanel Grid.Row="6">
                    <TextBlock Text="Phone" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtPhone"
                             Height="36"
                             FontSize="14"
                             Padding="10,0"
                             VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="8">
                    <TextBlock Text="Status" Margin="0,0,0,6" FontWeight="SemiBold"/>
                    <ComboBox x:Name="cbStatus"
                              Height="36"
                              FontSize="14">
                        <ComboBoxItem Content="Active"/>
                        <ComboBoxItem Content="Inactive"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="10"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="btnCancel"
                            Content="Cancel"
                            Width="100"
                            Height="36"
                            Margin="0,0,10,0"
                            Click="btnCancel_Click"/>
                    <Button x:Name="btnSave"
                            Content="Save"
                            Width="120"
                            Height="36"
                            Click="btnSave_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>