<Window x:Class="WPFApp.Views.Customer.CreateOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Order"
        Height="650" Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="22"/>
            <ColumnDefinition Width="1.2*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="16" Padding="15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Cart Items" FontSize="24" FontWeight="Bold" Foreground="#111827"/>

                <DataGrid x:Name="dgCart"
                          Grid.Row="1"
                          Margin="0,15,0,15"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="220"/>
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="120"/>
                        <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="90"/>
                        <DataGridTextColumn Header="Storage" Binding="{Binding StorageCapacity}" Width="100"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="70"/>
                        <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="110"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding LineTotal}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Remove Selected"
                            Width="140"
                            Height="36"
                            Margin="0,0,10,0"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"
                            Click="RemoveSelected_Click"/>
                    <Button Content="Clear Cart"
                            Width="120"
                            Height="36"
                            Background="#64748B"
                            Foreground="White"
                            BorderThickness="0"
                            Click="ClearCart_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2" Background="White" CornerRadius="16" Padding="18" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Shipping Information" FontSize="24" FontWeight="Bold" Foreground="#111827"/>

                <TextBlock Text="Receiver Name" Margin="0,20,0,6"/>
                <TextBox x:Name="txtReceiverName" Height="36"/>

                <TextBlock Text="Receiver Phone" Margin="0,14,0,6"/>
                <TextBox x:Name="txtReceiverPhone" Height="36"/>

                <TextBlock Text="Shipping Address" Margin="0,14,0,6"/>
                <TextBox x:Name="txtShippingAddress" Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>

                <Border Background="#F1F5F9" CornerRadius="12" Padding="12" Margin="0,20,0,0">
                    <StackPanel>
                        <TextBlock Text="Order Summary" FontWeight="Bold" FontSize="18"/>
                        <TextBlock x:Name="txtSummaryCount" Margin="0,10,0,4"/>
                        <TextBlock x:Name="txtSummaryTotal" FontSize="20" FontWeight="Bold" Foreground="#0F766E"/>
                    </StackPanel>
                </Border>

                <Button Content="Place Order"
                        Height="42"
                        Margin="0,20,0,0"
                        Background="#059669"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="PlaceOrder_Click"/>

                <Button Content="View My Orders"
                        Height="42"
                        Margin="0,12,0,0"
                        Background="#7C3AED"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Click="ViewOrders_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>