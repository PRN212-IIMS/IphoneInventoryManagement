<UserControl x:Class="WPFApp.Views.Customer.CustomerProductView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#374151"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="14" Padding="14" Margin="0,0,0,12" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2.6*"/>
        <ColumnDefinition Width="1.4*"/>
        <ColumnDefinition Width="1.4*"/>
        <ColumnDefinition Width="1.6*"/>
        <ColumnDefinition Width="1.6*"/>
        <ColumnDefinition Width="2*"/>
        <ColumnDefinition Width="2*"/>
    </Grid.ColumnDefinitions>

    <StackPanel Grid.Column="0" Margin="0,0,10,0">
        <TextBlock Text="Search keyword" Margin="0,0,0,5" FontSize="12"/>
        <TextBox x:Name="txtSearch" Height="36" Padding="8,0"/>
    </StackPanel>

    <StackPanel Grid.Column="1" Margin="0,0,10,0">
        <TextBlock Text="Color" Margin="0,0,0,5" FontSize="12"/>
        <ComboBox x:Name="cbColor" Height="36"/>
    </StackPanel>

    <StackPanel Grid.Column="2" Margin="0,0,10,0">
        <TextBlock Text="Storage" Margin="0,0,0,5" FontSize="12"/>
        <ComboBox x:Name="cbStorage" Height="36"/>
    </StackPanel>

    <Button Grid.Column="3"
            Content="Apply"
            Style="{StaticResource PrimaryButton}"
            HorizontalAlignment="Stretch"
            Margin="0,18,10,0"
            Background="#2563EB"
            Click="ApplyFilter_Click"/>

    <Button Grid.Column="4"
            Content="Reset"
            Style="{StaticResource PrimaryButton}"
            HorizontalAlignment="Stretch"
            Margin="0,18,10,0"
            Background="#64748B"
            Click="ResetFilter_Click"/>

    <Button Grid.Column="5"
            Content="Add To Cart"
            Style="{StaticResource PrimaryButton}"
            HorizontalAlignment="Stretch"
            Margin="0,18,10,0"
            Background="#059669"
            Click="AddToCart_Click"/>

    <Button Grid.Column="6"
            Content="Open Checkout"
            Style="{StaticResource PrimaryButton}"
            Margin="0,18,0,0"
            HorizontalAlignment="Stretch"
            Background="#7C3AED"
            Click="OpenCheckout_Click"/>
</Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="14" Padding="8" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgProducts"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      RowHeaderWidth="0"
                      RowHeight="54"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="60"/>
                    <DataGridTemplateColumn Header="Image" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Width="42" Height="42" CornerRadius="6" BorderBrush="#E2E8F0" BorderThickness="1" Background="#FFFFFF" Margin="2">
                                    <Image Source="{Binding UrlImages}" Stretch="UniformToFill"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="2*"/>
                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="1.2*"/>
                    <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="1*"/>
                    <DataGridTextColumn Header="Storage" Binding="{Binding StorageCapacity}" Width="1*"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=N0}" Width="1.1*"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="0.8*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Background="#EEF2FF" CornerRadius="12" Padding="12" Margin="0,12,0,0">
            <TextBlock x:Name="txtCartStatus"
                       Text="Cart: 0 item(s)"
                       FontWeight="SemiBold"
                       Foreground="#312E81"/>
        </Border>
    </Grid>
</UserControl>