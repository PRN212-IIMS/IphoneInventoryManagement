<Window x:Class="WPFApp.Views.Customer.CustomerMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iPhone Inventory - Customer"
        Height="700" Width="1200"
        MinHeight="650"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowState="Maximized"
        Background="#F4F7FB">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1E3A8A" CornerRadius="0,0,30,30" Padding="40">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Customer Portal"
                           Foreground="White"
                           FontSize="42"
                           FontWeight="Bold"/>
                <TextBlock Text="Browse products, create orders, and track your purchase history."
                           Margin="0,12,0,0"
                           Foreground="#DBEAFE"
                           FontSize="18"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="50,-50,50,50">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="30"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="18"
                    Padding="28"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Browse Products"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="View available products, search by keyword, and add items to cart."
                               Margin="0,14,0,24"
                               TextWrapping="Wrap"
                               Foreground="#4B5563"
                               FontSize="16"/>
                    <Button Content="Open Products"
                            Height="46"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            FontSize="16"
                            Click="OpenProducts_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="18"
                    Padding="28"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Create Order"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="Review your cart, enter shipping information, and place an order."
                               Margin="0,14,0,24"
                               TextWrapping="Wrap"
                               Foreground="#4B5563"
                               FontSize="16"/>
                    <Button Content="Open Checkout"
                            Height="46"
                            Background="#059669"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            FontSize="16"
                            Click="OpenCheckout_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Background="White"
                    CornerRadius="18"
                    Padding="28"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="My Orders"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="Track your orders, view details, and cancel pending orders."
                               Margin="0,14,0,24"
                               TextWrapping="Wrap"
                               Foreground="#4B5563"
                               FontSize="16"/>
                    <Button Content="Open Order History"
                            Height="46"
                            Background="#7C3AED"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            FontSize="16"
                            Click="OpenOrders_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>