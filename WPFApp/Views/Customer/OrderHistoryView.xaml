<UserControl x:Class="WPFApp.Views.Customer.OrderHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#F8FAFC"
                CornerRadius="14"
                Padding="10"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <DataGrid x:Name="dgOrders"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeaderWidth="0"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="110"/>
                    <DataGridTextColumn Header="Receiver" Binding="{Binding ReceiverName}" Width="2*"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding ReceiverPhone}" Width="1.3*"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding ShippingAddress}" Width="2.2*"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="1*"/>
                    <DataGridTextColumn Header="Order Date" Binding="{Binding OrderDate}" Width="1.4*"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=N0}" Width="1.1*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Refresh"
                    Width="110"
                    Height="36"
                    Margin="0,0,10,0"
                    Background="#2563EB"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Refresh_Click"/>
            <Button Content="View Detail"
                    Width="120"
                    Height="36"
                    Background="#0F766E"
                    Foreground="White"
                    BorderThickness="0"
                    Click="ViewDetail_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
