<UserControl x:Class="WPFApp.Views.Customer.OrderHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <UserControl.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="14" Padding="15" Margin="0,0,0,14" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Refresh"
                        Width="100"
                        Style="{StaticResource ActionButton}"
                        Margin="0,0,10,0"
                        Background="#2563EB"
                        Click="Refresh_Click"/>
                <Button Content="View Detail"
                        Width="120"
                        Style="{StaticResource ActionButton}"
                        Margin="0,0,10,0"
                        Background="#0F766E"
                        Click="ViewDetail_Click"/>
                <Button Content="Cancel Order"
                        Width="130"
                        Style="{StaticResource ActionButton}"
                        Background="#DC2626"
                        Click="CancelOrder_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="14" Padding="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgOrders"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      RowHeaderWidth="0"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="80"/>
                    <DataGridTextColumn Header="Order Date" Binding="{Binding OrderDate}" Width="160"/>
                    <DataGridTextColumn Header="Receiver" Binding="{Binding ReceiverName}" Width="150"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding ReceiverPhone}" Width="120"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding ShippingAddress}" Width="250"/>
                    <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount, StringFormat=N0}" Width="120"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>