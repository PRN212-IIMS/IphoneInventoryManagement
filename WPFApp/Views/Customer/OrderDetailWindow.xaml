<Window x:Class="WPFApp.Views.Customer.OrderDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Order Detail"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Order Detail"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#0F172A"/>

        <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="16" Margin="0,15,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="txtOrderId" FontWeight="Bold" FontSize="16"/>
                    <TextBlock x:Name="txtReceiver" Margin="0,8,0,0"/>
                    <TextBlock x:Name="txtPhone" Margin="0,8,0,0"/>
                    <TextBlock x:Name="txtAddress" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="txtStatus" FontWeight="Bold" FontSize="16"/>
                    <TextBlock x:Name="txtOrderDate" Margin="0,8,0,0"/>
                    <TextBlock x:Name="txtTotalAmount" Margin="0,8,0,0" FontWeight="Bold" Foreground="#0F766E"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgOrderDetails"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product" Binding="{Binding Product.ProductName}" Width="250"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="90"/>
                    <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice}" Width="120"/>
                    <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnCancelOrder"
                    Content="Cancel Order"
                    Width="130"
                    Height="36"
                    Margin="0,0,10,0"
                    Background="#DC2626"
                    Foreground="White"
                    BorderThickness="0"
                    Click="CancelOrder_Click"/>
            <Button Content="Close"
                    Width="100"
                    Height="36"
                    Background="#64748B"
                    Foreground="White"
                    BorderThickness="0"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>