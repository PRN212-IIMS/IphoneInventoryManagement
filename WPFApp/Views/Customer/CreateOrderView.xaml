<UserControl x:Class="WPFApp.Views.Customer.CreateOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <UserControl.Resources>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#E0E7FF"/>
            <Setter Property="Foreground" Value="#1E3A8A"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="BorderBrush" Value="#C7D2FE"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1E3A8A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.25*"/>
            <ColumnDefinition Width="22"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: CART -->
        <Border Grid.Column="0"
                Background="#F8FAFC"
                CornerRadius="18"
                Padding="18"
                BorderBrush="#E2E8F0"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Cart Items"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="Review selected products before placing the order"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="#64748B"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="0,16,0,16"
                        Background="White"
                        CornerRadius="14"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Padding="8">
                    <DataGrid x:Name="dgCart"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              RowHeaderWidth="0"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              GridLinesVisibility="None"
                              HeadersVisibility="Column"
                              BorderThickness="0"
                              Background="Transparent"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"
                                                Binding="{Binding ProductName}"
                                                Width="170"/>
                            <DataGridTextColumn Header="Model"
                                                Binding="{Binding Model}"
                                                Width="105"/>
                            <DataGridTextColumn Header="Color"
                                                Binding="{Binding Color}"
                                                Width="85"/>
                            <DataGridTextColumn Header="Storage"
                                                Binding="{Binding StorageCapacity}"
                                                Width="90"/>
                            <DataGridTextColumn Header="Qty"
                                                Binding="{Binding Quantity}"
                                                Width="55"/>
                            <DataGridTextColumn Header="Unit Price"
                                                Binding="{Binding UnitPrice, StringFormat={}{0:N0}}"
                                                Width="105"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat=N0}" Width="1.1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Remove Selected"
                            Width="145"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,10,0"
                            Background="#DC2626"
                            Click="RemoveSelected_Click"/>
                    <Button Content="Clear Cart"
                            Width="120"
                            Style="{StaticResource PrimaryButton}"
                            Background="#64748B"
                            Click="ClearCart_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2"
        Background="#F8FAFC"
        CornerRadius="18"
        Padding="18"
        BorderBrush="#E2E8F0"
        BorderThickness="1">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Shipping Information"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#111827"/>
            <TextBlock Text="Fill in delivery details and confirm your order"
                       Margin="0,4,0,0"
                       FontSize="13"
                       Foreground="#64748B"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Form content -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="38"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="78"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Receiver Name"
                       Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Foreground="#334155"/>
            <TextBox Grid.Row="1" x:Name="txtReceiverName"/>

            <TextBlock Grid.Row="3"
                       Text="Receiver Phone"
                       Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Foreground="#334155"/>
            <TextBox Grid.Row="4" x:Name="txtReceiverPhone"/>

            <TextBlock Grid.Row="6"
                       Text="Shipping Address"
                       Margin="0,0,0,6"
                       FontWeight="SemiBold"
                       Foreground="#334155"/>
            <TextBox Grid.Row="7"
                     x:Name="txtShippingAddress"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"
                     Padding="10"/>

            <Border Grid.Row="9"
                    Background="White"
                    CornerRadius="14"
                    Padding="14"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Order Summary"
                               FontWeight="Bold"
                               FontSize="18"
                               Foreground="#0F172A"/>
                    <Separator Margin="0,10,0,10" Background="#E2E8F0"/>
                    <TextBlock x:Name="txtSummaryCount"
                               Margin="0,0,0,6"
                               FontSize="14"
                               Foreground="#475569"/>
                    <TextBlock x:Name="txtSummaryTotal"
                               FontSize="21"
                               FontWeight="Bold"
                               Foreground="#059669"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bottom button -->
        <Button Grid.Row="2"
                Content="Place Order"
                Height="44"
                Margin="0,14,0,0"
                Style="{StaticResource PrimaryButton}"
                Background="#059669"
                Click="PlaceOrder_Click"/>
    </Grid>
</Border>
    </Grid>
</UserControl>