<Window x:Class="WPFApp.Views.Staff.CreateStockInWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Stock In"
        Height="680" Width="950"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F7FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Create Stock In"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#19345C"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Select Product:"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>

            <ComboBox x:Name="cbProducts"
                      Grid.Column="1"
                      Height="32"
                      Margin="0,0,10,0"
                      DisplayMemberPath="ProductName"
                      SelectedValuePath="ProductId"/>

            <TextBlock Grid.Column="2"
                       Text="Quantity:"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="10,0,0,0"/>

            <TextBox x:Name="txtQuantity"
                     Grid.Column="3"
                     Height="32"
                     Margin="10,0,10,0"
                     VerticalContentAlignment="Center"/>

            <Button x:Name="btnAddItem"
                    Grid.Column="4"
                    Content="Add Item"
                    Width="100"
                    Height="32"
                    Click="btnAddItem_Click"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Unit Import Price:"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="txtImportPrice"
                     Grid.Column="1"
                     Height="32"
                     Margin="0,0,10,0"
                     VerticalContentAlignment="Center"/>

            <TextBlock Grid.Column="2"
                       Text="Import price is the price for one product unit."
                       VerticalAlignment="Center"
                       Foreground="#6B7C93"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Note:"
                       VerticalAlignment="Top"
                       FontWeight="SemiBold"/>

            <TextBox x:Name="txtNote"
                     Grid.Column="1"
                     Height="60"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalContentAlignment="Top"/>
        </Grid>

        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <DataGrid x:Name="dgDetails"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      RowHeight="36"
                      ColumnHeaderHeight="36">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="90"/>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="220"/>
                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="Unit Import Price" Binding="{Binding ImportPrice, StringFormat={}{0:N0}}" Width="150"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, StringFormat={}{0:N0}}" Width="150"/>

                    <DataGridTemplateColumn Header="Actions" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Remove"
                                        Width="80"
                                        Height="28"
                                        Click="btnRemoveItem_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button x:Name="btnSave"
                    Content="Save Stock In"
                    Width="120"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="btnSave_Click"/>

            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="100"
                    Height="34"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>