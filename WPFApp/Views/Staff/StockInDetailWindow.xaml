<Window x:Class="WPFApp.Views.Staff.StockInDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stock In Detail"
        Height="620" Width="960"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F7FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Stock In Detail"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#19345C"
                   Margin="0,0,0,20"/>

        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="36"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Stock In ID:"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="txtStockInId"
                           Grid.Row="0" Grid.Column="1"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="Created By:"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="txtCreatedBy"
                           Grid.Row="0" Grid.Column="3"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Stock In Date:"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="txtStockInDate"
                           Grid.Row="1" Grid.Column="1"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Note:"
                           FontWeight="SemiBold"
                           VerticalAlignment="Top"/>
                <TextBlock x:Name="txtNote"
                           Grid.Column="1"
                           TextWrapping="Wrap"
                           VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="8">
            <DataGrid x:Name="dgDetails"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      RowHeight="36"
                      ColumnHeaderHeight="36">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product ID"
                                        Binding="{Binding ProductId}"
                                        Width="90"/>

                    <DataGridTextColumn Header="Product Name"
                                        Binding="{Binding ProductName}"
                                        Width="240"/>

                    <DataGridTextColumn Header="Quantity"
                                        Binding="{Binding Quantity}"
                                        Width="100"/>

                    <DataGridTextColumn Header="Unit Import Price"
                                        Binding="{Binding ImportPrice, StringFormat={}{0:N0}}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Total"
                                        Binding="{Binding Total, StringFormat={}{0:N0}}"
                                        Width="150"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Content="Close"
                    Width="100"
                    Height="34"
                    Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>