<UserControl x:Class="WPFApp.Views.Staff.StaffAiAssistantView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="AI Assistant"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="#19345C"/>
            <TextBlock Text="Ask questions about inventory, orders, and stock-in activity. Supported question types are answered directly from the database."
                       Margin="0,8,0,0"
                       FontSize="16"
                       Foreground="#6D84A2"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Background="White"
                    BorderBrush="#DCE7F2"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Ask a question"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#19345C"/>
                    <TextBlock Grid.Row="1"
                               Margin="0,8,0,0"
                               Text="Example: Which products are low on stock? Show pending orders. Show active black 128GB products."
                               Foreground="#6D84A2"
                               TextWrapping="Wrap"/>

                    <TextBox x:Name="txtQuestion"
                             Grid.Row="2"
                             Margin="0,16,0,0"
                             MinHeight="180"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalContentAlignment="Top"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="15"/>

                    <StackPanel Grid.Row="3" Margin="0,18,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="btnClear"
                                Content="Clear"
                                Width="100"
                                Height="36"
                                Margin="0,0,10,0"
                                Click="btnClear_Click"/>
                        <Button x:Name="btnAsk"
                                Content="Ask AI"
                                Width="120"
                                Height="36"
                                Click="btnAsk_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#DCE7F2"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="22">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Response"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="#19345C"/>
                        <TextBlock Margin="0,8,0,0"
                                   Text="Direct database answers are prioritized. LM Studio is used only as a fallback for unsupported questions."
                                   Foreground="#6D84A2"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBox x:Name="txtAnswer"
                             Grid.Row="1"
                             Margin="0,18,0,0"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"
                             Background="#F8FBFE"
                             BorderBrush="#E5EEF7"
                             BorderThickness="1"
                             FontSize="15"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
