<Window x:Class="WPFApp.Views.Staff.CreateOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Order"
        Height="700" Width="1050"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F7FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Create Order"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#19345C"
                   Margin="0,0,0,20"/>

        <!-- Order information -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="42"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="Customer (optional):"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <ComboBox x:Name="cbCustomers"
                          Grid.Row="0" Grid.Column="1"
                          Height="32"
                          Margin="0,0,12,0"
                          DisplayMemberPath="FullName"
                          SelectedValuePath="CustomerId"/>

                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="Receiver Name:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="txtReceiverName"
                         Grid.Row="0" Grid.Column="3"
                         Height="32"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="Receiver Phone:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="txtReceiverPhone"
                         Grid.Row="1" Grid.Column="1"
                         Height="32"
                         Margin="0,0,12,0"
                         VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2"
                           Text="Shipping Address:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="txtShippingAddress"
                         Grid.Row="1" Grid.Column="3"
                         Height="32"
                         VerticalContentAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Add product -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="320"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Select Product:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <ComboBox x:Name="cbProducts"
                          Grid.Column="1"
                          Height="32"
                          Margin="0,0,12,0"
                          DisplayMemberPath="ProductName"
                          SelectedValuePath="ProductId"/>

                <TextBlock Grid.Column="2"
                           Text="Quantity:"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>

                <TextBox x:Name="txtQuantity"
                         Grid.Column="3"
                         Height="32"
                         Margin="0,0,12,0"
                         VerticalContentAlignment="Center"/>

                <Button x:Name="btnAddItem"
                        Grid.Column="4"
                        Content="Add Item"
                        Width="100"
                        Height="32"
                        Click="btnAddItem_Click"/>

                <TextBlock Grid.Column="5"
                           Text="Unit price will be taken automatically from Product.Price."
                           VerticalAlignment="Center"
                           Margin="15,0,0,0"
                           Foreground="#6B7C93"/>
            </Grid>
        </Border>

        <!-- Detail list -->
        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#D9E2EC"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="txtTotalAmount"
                           Text="Total Amount: 0"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#19345C"
                           Margin="0,0,0,12"/>

                <DataGrid x:Name="dgDetails"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          RowHeight="36"
                          ColumnHeaderHeight="36">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product ID" Binding="{Binding ProductId}" Width="90"/>
                        <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="260"/>
                        <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                        <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat={}{0:N0}}" Width="140"/>
                        <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat={}{0:N0}}" Width="150"/>

                        <DataGridTemplateColumn Header="Actions" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Remove"
                                            Width="80"
                                            Height="28"
                                            Click="btnRemoveItem_Click"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button x:Name="btnSave"
                    Content="Save Order"
                    Width="120"
                    Height="34"
                    Margin="0,0,10,0"
                    Click="btnSave_Click"/>

            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="100"
                    Height="34"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>