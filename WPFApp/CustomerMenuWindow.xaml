<Window x:Class="WPFApp.CustomerMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="iPhone Inventory - Customer"
        Height="520" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F7FB">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="180"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1E3A8A" CornerRadius="0,0,30,30" Padding="30">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Customer Portal"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"/>
                <TextBlock Text="Browse products, create orders, and track your purchase history."
                           Margin="0,10,0,0"
                           Foreground="#DBEAFE"
                           FontSize="16"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="40,-40,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="25"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="18" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Browse Products" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="View available products, search by keyword, and add items to cart."
                               Margin="0,10,0,20"
                               TextWrapping="Wrap"
                               Foreground="#4B5563"/>
                    <Button Content="Open Products"
                            Height="42"
                            Background="#2563EB"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Click="OpenProducts_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" CornerRadius="18" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Create Order" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Review your cart, enter shipping information, and place an order."
                               Margin="0,10,0,20"
                               TextWrapping="Wrap"
                               Foreground="#4B5563"/>
                    <Button Content="Open Checkout"
                            Height="42"
                            Background="#059669"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Click="OpenCheckout_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="White" CornerRadius="18" Padding="20" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="My Orders" FontSize="24" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock Text="Track your orders, view details, and cancel pending orders."
                               Margin="0,10,0,20"
                               TextWrapping="Wrap"
                               Foreground="#4B5563"/>
                    <Button Content="Open Order History"
                            Height="42"
                            Background="#7C3AED"
                            Foreground="White"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            Click="OpenOrders_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>