<Window x:Class="WPFApp.CustomerProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Products"
        Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Available Products"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#0F172A"/>

        <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="15" Margin="0,15,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Search keyword" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtSearch" Height="34"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Color" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cbColor" Height="34"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <TextBlock Text="Storage" Margin="0,0,0,6"/>
                        <ComboBox x:Name="cbStorage" Height="34"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <TextBlock Text="Quantity" Margin="0,0,0,6"/>
                        <TextBox x:Name="txtQuantity" Height="34" Text="1"/>
                    </StackPanel>

                    <Button Grid.Column="4"
                            Content="Apply"
                            Height="34"
                            Margin="0,24,12,0"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Click="ApplyFilter_Click"/>
                </Grid>

                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,15,0,0">
                    <Button Content="Reset"
                            Width="90"
                            Height="34"
                            Margin="0,0,10,0"
                            Background="#64748B"
                            Foreground="White"
                            BorderThickness="0"
                            Click="ResetFilter_Click"/>

                    <Button Content="Add To Cart"
                            Width="120"
                            Height="34"
                            Margin="0,0,10,0"
                            Background="#059669"
                            Foreground="White"
                            BorderThickness="0"
                            Click="AddToCart_Click"/>

                    <Button Content="Open Checkout"
                            Width="130"
                            Height="34"
                            Background="#7C3AED"
                            Foreground="White"
                            BorderThickness="0"
                            Click="OpenCheckout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgProducts"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding ProductId}" Width="60"/>
                    <DataGridTextColumn Header="Product Name" Binding="{Binding ProductName}" Width="230"/>
                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="130"/>
                    <DataGridTextColumn Header="Color" Binding="{Binding Color}" Width="100"/>
                    <DataGridTextColumn Header="Storage" Binding="{Binding StorageCapacity}" Width="110"/>
                    <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="120"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding StockQuantity}" Width="90"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Background="#EEF2FF" CornerRadius="12" Padding="12" Margin="0,15,0,0">
            <TextBlock x:Name="txtCartStatus"
                       Text="Cart: 0 item(s)"
                       FontWeight="SemiBold"
                       Foreground="#312E81"/>
        </Border>
    </Grid>
</Window>