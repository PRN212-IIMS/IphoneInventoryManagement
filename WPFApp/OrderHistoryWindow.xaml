<Window x:Class="WPFApp.OrderHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Order History"
        Height="620" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="My Orders"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="#0F172A"/>

        <Border Grid.Row="1" Background="White" CornerRadius="16" Padding="15" Margin="0,15,0,15" BorderBrush="#E2E8F0" BorderThickness="1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Refresh"
                        Width="100"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Refresh_Click"/>
                <Button Content="View Detail"
                        Width="120"
                        Height="36"
                        Margin="0,0,10,0"
                        Background="#0F766E"
                        Foreground="White"
                        BorderThickness="0"
                        Click="ViewDetail_Click"/>
                <Button Content="Cancel Order"
                        Width="130"
                        Height="36"
                        Background="#DC2626"
                        Foreground="White"
                        BorderThickness="0"
                        Click="CancelOrder_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="10" BorderBrush="#E2E8F0" BorderThickness="1">
            <DataGrid x:Name="dgOrders"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="80"/>
                    <DataGridTextColumn Header="Order Date" Binding="{Binding OrderDate}" Width="160"/>
                    <DataGridTextColumn Header="Receiver" Binding="{Binding ReceiverName}" Width="150"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding ReceiverPhone}" Width="120"/>
                    <DataGridTextColumn Header="Address" Binding="{Binding ShippingAddress}" Width="250"/>
                    <DataGridTextColumn Header="Total Amount" Binding="{Binding TotalAmount}" Width="120"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>